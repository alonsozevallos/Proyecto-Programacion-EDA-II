{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run Proyecto EDA II",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "main.cpp",
        "avl.cpp",
        "estudiante.cpp",
        "hash Chaining.cpp",
        "heap.cpp",
        "search.cpp",
        "-o",
        "main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}